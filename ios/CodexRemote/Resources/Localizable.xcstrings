    "conn.error.appServerUnreachable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "app-server unreachable. Check that the Mac launch script has enabled managed daemon remote control."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "app-server 不可达，请检查 Mac 端启动脚本是否已启用受管 daemon 远程控制。"
          }
        }
      }
    },
    "conn.error.authFailed %@": {
      "localizations": {
